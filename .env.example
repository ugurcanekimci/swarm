# Swarm Knowledge Ingestion System

# Server port (default: 3100)
PORT=3100

# Data directory for legacy cache (default: ./data)
# DATA_DIR=./data

# Cache TTL in milliseconds (default: 86400000 = 24h)
# CACHE_TTL=86400000

# Batch processing concurrency (default: 3)
# BATCH_CONCURRENCY=3

# Default transcript language (default: en)
# DEFAULT_LANGUAGE=en

# Apify API token (optional — enables fallback scrapers)
# APIFY_API_TOKEN=apify_api_...

# Obsidian vault path (shared knowledge base)
# OBSIDIAN_VAULT=/Users/u/Documents/swarm-kb

# Residential proxy config (optional — for protected site scraping)
# PROXY_HOST=gate.iproyal.com
# PROXY_PORT=12321
# PROXY_USER=your_user
# PROXY_PASS=your_pass

# Crawl4AI self-hosted instance
# CRAWL4AI_URL=http://localhost:11235

# Camoufox browser REST API
# CAMOFOX_URL=http://localhost:9377

# Context optimization
# MAX_TOOL_RESULT_TOKENS=4000
# MAX_SEARCH_RESULTS=10

# Ollama local model server
# OLLAMA_URL=http://localhost:11434
