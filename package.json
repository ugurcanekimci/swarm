{
  "name": "swarm-youtube-transcript",
  "version": "1.0.0",
  "description": "YouTube transcript API layer for swarm knowledge base",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "audit": "npm audit",
    "mcp": "tsx src/mcp/stdio.ts"
  },
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.5",
    "langfuse": "3.38.6",
    "node-cron": "^4.2.1",
    "yaml": "^2.8.2",
    "youtube-transcript-plus": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/node-cron": "^3.0.11",
    "eslint": "^10.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
